{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string", "format": "uri" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "email"]
    },
    "Album": {
      "title": "Album",
      "description": "A collection of photos",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "coverUrl": { "type": "string", "format": "uri" },
        "photoCount": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "userId", "name", "createdAt"]
    },
    "Photo": {
      "title": "Photo",
      "description": "An individual photo entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "albumId": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "number" },
        "width": { "type": "number" },
        "height": { "type": "number" }
      },
      "required": ["id", "userId", "albumId", "url", "title", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/albums/{albumId}": {
      "schema": "Album",
      "description": "Photo albums"
    },
    "/photos/{photoId}": {
      "schema": "Photo",
      "description": "Photo library"
    }
  }
}
